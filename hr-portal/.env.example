# 复制为 .env 并按环境填写。所有变量已在 docker-compose.yml 中映射到对应服务。

# ===== 应用 =====
APP_ENV=dev

# ===== 数据库（首次启动会用这套凭证创建数据库）=====
DB_NAME=hr_portal
DB_USER=hr_portal
DB_PASSWORD=change-me-please

# ===== JWT 签名密钥（生产环境请用至少 32 字符的强随机字符串）=====
JWT_SECRET=please-change-this-to-a-long-random-string

# ===== 首次启动注入的 admin 密码 =====
ADMIN_INIT_PASSWORD=Admin@2026

# ===== 北森 OpenAPI 凭证（找北森对接人要）=====
BEISEN_BASE_URL=
BEISEN_APP_KEY=
BEISEN_APP_SECRET=

# ===== 组织树根节点名（FR-TREE-001）=====
ORG_ROOT_NAME=创梦天地

# ===== 飞书单点登录（用飞书账号登录 HR Portal）=====
# 启用前需在飞书开放平台创建自建应用，并把回调地址加入「安全设置-重定向 URL」白名单
FEISHU_SSO_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 回调地址，必须与开放平台白名单完全一致（生产示例：http://192.168.10.13:37801/auth/feishu/callback）
FEISHU_REDIRECT_URI=http://localhost:8080/auth/feishu/callback
# ?? Bot ??????????????????????
FEISHU_VERIFICATION_TOKEN=
FEISHU_CALLBACK_MAX_TIMESTAMP_DIFF=300
FEISHU_BOT_ENABLED=false
# ??????????????????? Portal user_id??? fail closed?
FEISHU_EMPLOYEE_PROFILE_ENABLED=false
FEISHU_EMPLOYEE_PROFILE_ALLOWED_USER_IDS=

# ===== Employee profile controlled rollout (fail closed) =====
EMPLOYEE_PROFILE_ENABLED=false
EMPLOYEE_PROFILE_ALLOWED_USER_IDS=
# UTC ISO-8601 timestamp, for example 2026-07-31T16:00:00+00:00
EMPLOYEE_PROFILE_EXPIRES_AT=

# ===== Shared AI capability rate limit =====
AI_CAPABILITY_RATE_LIMIT_MAX_REQUESTS=20
AI_CAPABILITY_RATE_LIMIT_WINDOW_SECONDS=300
AI_CONTROLLED_ACTION_AUDIT_RETENTION_DAYS=180
AI_CONTROLLED_ACTION_STATE_RETENTION_DAYS=7
AI_CONTROLLED_ACTION_TTL_SECONDS=300
