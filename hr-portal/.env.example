# 复制为 .env 并按环境填写。所有变量已在 docker-compose.yml 中映射到对应服务。

# ===== 应用 =====
APP_ENV=dev

# ===== 数据库（首次启动会用这套凭证创建数据库）=====
DB_NAME=hr_portal
DB_USER=hr_portal
DB_PASSWORD=change-me-please

# ===== JWT 签名密钥（生产环境请用至少 32 字符的强随机字符串）=====
JWT_SECRET=please-change-this-to-a-long-random-string

# ===== 首次启动注入的 admin 密码 =====
ADMIN_INIT_PASSWORD=admin123

# ===== 北森 OpenAPI 凭证（找北森对接人要）=====
BEISEN_BASE_URL=
BEISEN_APP_KEY=
BEISEN_APP_SECRET=

# ===== 组织树根节点名（FR-TREE-001）=====
ORG_ROOT_NAME=创梦天地